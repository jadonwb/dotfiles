{
    "$schema": "https://opencode.ai/tui.json",
    "scroll_speed": 5,
    "scroll_acceleration": {
        "enabled": true
    },
    "diff_style": "auto",
    "plugin": [
        "@tarquinen/opencode-dcp@latest",
    ],
    "keybinds": {
        "messages_line_up": "alt+k",
        "messages_line_down": "alt+j",
        "command_list": "ctrl+space",
        "history_previous": "ctrl+p",
        "history_next": "ctrl+n",
    },
    "attention": {
        "enabled": true,
        "notifications": true,
        "sound": false,
        "volume": 0.0
    }
}
