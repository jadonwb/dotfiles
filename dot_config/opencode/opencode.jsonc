{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "./plugins/brief_path.ts",
        "./plugins/dispatch.ts",
        "@tarquinen/opencode-dcp@latest",
    ],
    "model": "deepseek/deepseek-v4-pro",
    "small_model": "deepseek/deepseek-v4-flash",
    "default_agent": "orchestrate",
    "command": {
        "brief-path": {
            "template": "IGNORED",
            "description": "Show the brief file path for the current session"
        }
    },
    "agent": {
        "build": {
            "disable": true
        },
        "plan": {
            "disable": true
        },
        "general": {
            "disable": true
        },
        "explore": {
            "disable": true
        }
    },
    "compaction": {
        "auto": false,
    }
}
