{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "./plugins/brief_path.ts",
        "@tarquinen/opencode-dcp@latest",
    ],
    "model": "deepseek/deepseek-v4-pro",
    "small_model": "deepseek/deepseek-v4-flash",
    "default_agent": "orchestrate",
    "agent": {
        "build": {
            "disable": true
        },
        "plan": {
            "disable": true
        },
        "general": {
            "disable": true
        },
        "explore": {
            "disable": true
        }
    },
    "compaction": {
        "auto": false,
        "prune": false,
    },
}
