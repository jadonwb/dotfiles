{{- if eq .machine.type "work" }}
hl.window_rule({
  name = "chromium-browser-opacity",
  match = { tag = "chromium-based-browser" },
  opacity = "0.95 override 0.9 override",
})
{{- else }}
hl.window_rule({
  name = "chromium-browser-opacity",
  match = { tag = "chromium-based-browser" },
  opacity = "0.87 0.83",
})
{{- end }}

hl.window_rule({
  name = "yazi-special",
  match = { class = "org.omarchy.yazi" },
  float = true,
  center = true,
  size = { "(monitor_w*0.8)", "(monitor_h*0.8)" },
})

hl.window_rule({
  name = "text-box",
  match = { class = "text.box" },
  float = true,
  center = true,
  size = { "(monitor_w*0.4)", "(monitor_h*0.4)" },
})

hl.window_rule({
  name = "popterm",
  match = { class = "org.jadon.popterm" },
  float = true,
  pin = true,
  size = { "(monitor_w*0.35)", "(monitor_h*0.3)" },
  move = { "(monitor_w*0.64)", "(monitor_h*0.62)" },
})

hl.window_rule({
  name = "gstreamer",
  match = { class = "GStreamer" },
  no_anim = true,
  rounding = 0,
  opacity = "1.0 override 1.0 override",
  float = true,
  center = true,
})

hl.window_rule({
  name = "btop-tag",
  match = { class = "org.omarchy.btop" },
  tag = "-floating-window",
})

hl.window_rule({
  name = "btop-size",
  match = { class = "org.omarchy.btop" },
  float = true,
  center = true,
  size = { "(monitor_w*0.8)", "(monitor_h*0.9)" },
})

hl.window_rule({
  name = "vesktop-media",
  match = { class = "vesktop" },
  workspace = "special:media",
})

hl.window_rule({
  name = "screensaver",
  match = { class = "^(org\\.omarchy\\.screensaver)$" },
  no_anim = true,
  rounding = 0,
})

hl.window_rule({
  name = "ghostty-min-size",
  match = { class = "^(com\\.mitchellh\\.ghostty)$" },
  min_size = { 960, 640 },
  center = true,
})
