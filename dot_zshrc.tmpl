if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

{{- if eq .machine.type "work" }}
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
eval "$(fzf --zsh)"
{{- end}}

stty -ixon < /dev/tty

# exports for interactive shell
export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS --ansi --color=16"
export _ZO_EXCLUDE_DIRS="/net/*:/media/*:/tmp/*"
export MANPAGER='nvim +Man!'
export BAT_THEME=ansi

# Set the directory we want to store zinit and plugins
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"

# Download Zinit, if its not there yet
if [ ! -d "$ZINIT_HOME" ]; then
  mkdir -p "$(dirname $ZINIT_HOME)"
  git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi

# Source/load zinit
source "${ZINIT_HOME}/zinit.zsh"


# Add in zsh plugins
# prompt
zinit ice depth=1; zinit light romkatv/powerlevel10k

# don't wait for these
zinit light zsh-users/zsh-autosuggestions
zinit light jeffreytse/zsh-vi-mode
zinit light zsh-users/zsh-syntax-highlighting

zinit ice wait lucid atload'eval "$(zoxide init --cmd cd zsh)"'
zinit light ajeetdsouza/zoxide
zinit ice wait lucid
zinit light jdx/mise
zinit ice wait lucid multisrc"shell/{completion,key-bindings}.zsh"
zinit light junegunn/fzf
zinit ice wait lucid
zinit light zsh-users/zsh-completions
zinit ice wait lucid
zinit light Aloxaf/fzf-tab

ZVM_SYSTEM_CLIPBOARD_ENABLED=true
ZVM_VI_HIGHLIGHT_FOREGROUND=#c8d3f5
ZVM_VI_HIGHLIGHT_BACKGROUND=#161440

# Add in snippets
zinit ice wait lucid
zinit snippet OMZP::git
zinit ice wait lucid
zinit snippet OMZP::sudo
{{- if eq .machine.type "personal" }}
zinit ice wait lucid
zinit snippet OMZP::archlinux
{{- end}}
{{- if eq .machine.type "laptop" }}
zinit ice wait lucid
zinit snippet OMZP::archlinux
{{- end}}
zinit ice wait lucid
zinit snippet OMZP::command-not-found

# Load completions
autoload -Uz compinit
compinit -C

zinit cdreplay -q

# Keybindings
zvm_after_init() {
  bindkey '^p' history-search-backward
  bindkey '^n' history-search-forward
}
bindkey -r '^s'
bindkey -r '^q'

bindkey -M vicmd '!' sudo-command-line
bindkey -M viins '^[[33;5u' sudo-command-line

bindkey '^[[Z' autosuggest-accept # Shift-Tab to accept autosuggestions

# History
HISTSIZE=10000
HISTFILE=~/.zsh_history
SAVEHIST=$HISTSIZE
HISTDUP=erase
setopt inc_append_history
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_ignore_dups
setopt hist_find_no_dups

# Completion styling
zstyle ':fzf-tab:*' fzf-flags ${(z)FZF_DEFAULT_OPTS}
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'ls --color $realpath'

# Aliases
alias make='bear -- make'
alias vim='nvim'
alias t='tmux attach || tmux new -s Work'
alias c='clear'
alias q='exit'
alias fd='fd -H'
alias sg='rg --hidden'
alias ls='eza --long --no-user --header --icons --git --group-directories-first'
alias lsu='eza --long --header --icons --git --group-directories-first'
alias lsg='eza --long --group --header --icons --git --group-directories-first'
alias lsa='eza --long --no-user --header --icons --git --all --group-directories-first'
alias lt='eza --long --no-user --header --icons --git --group-directories-first --tree'
alias lta='eza --long --no-user --header --icons --git --all --group-directories-first --tree'
alias lg="lazygit"
alias vlg="nvim +'lua Snacks.lazygit()'"
alias oc="opencode"
alias dots="chezmoi"

svim() { sudoedit "$@" }

open() {
  xdg-open "$@" >/dev/null 2>&1 &
}

deref() {
  local f real dir
  for f in "$@"; do
    [[ -L $f ]] || continue

    dir=$(dirname -- "$f")
    real=$(readlink -- "$f") || continue

    rm -- "$f" || continue
    cp -- "$dir/$real" "$f"
  done
}

zd() {
  if (( $# == 0 )); then
    builtin cd ~ || return
  elif [[ -d $1 ]]; then
    builtin cd "$1" || return
  else
    if ! __zoxide_z "$@" 2>/dev/null; then
      echo "Error: Directory not found"
      return 1
    fi
    printf "\U000F17A9 "
    pwd
  fi
}

alias cd="zd"

alias ..='builtin cd ..'
alias ...='builtin cd ../..'
alias ....='builtin cd ../../..'
alias .....='builtin cd ../../../..'
alias ......='builtin cd ../../../../..'

# Shell integrations
if command -v try &> /dev/null; then
  eval "$(try init ~/c/tries)"
fi

export TMUX_PLUGIN_MANAGER_PATH="$HOME/.config/tmux/plugins/"

source $HOME/.zfuncs
{{- if eq .machine.type "personal" }}
source $HOME/.zsh_secrets
{{- end}}

{{- if eq .machine.type "work" }}
umask 007
{{- end}}

[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
