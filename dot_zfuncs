# For my yocto work
reflash() {
    sudo umount "$1"* > /dev/null 2>&1
    sudo dd if=/dev/zero of="$1" bs=1M count=100 && sync
    sudo bmaptool copy "$2" "$1"
  }

# When my dictionary changes
dictionary() {
    chezmoi re-add $HOME/.config/harper-ls/dictionary.txt
  }

restore_hyprlock() {
    hyprctl --instance 0 eval 'hl.config({ misc = { allow_session_lock_restore = true } })'
    hyprctl --instance 0 dispatch 'hl.dsp.exec_cmd("hyprlock")'
    }
